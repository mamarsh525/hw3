<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Random Character</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <%- include('partials/nav') %>

  <main class="container">
    <section class="search-section">
      <h1>Random Character</h1>
      <p>Click the button to see a random Rick & Morty character</p>

      <form method="GET" action="/random" class="search-form">
        <button type="submit" class="btn">Get Random Character</button>
      </form>

      <% if (error) { %>
        <div class="alert alert-error">
          <%= error %>
        </div>
      <% } %>

      <% if (character) { %>
        <div class="character-grid">
          <div class="character-card">
            <img src="<%= character.image %>" alt="<%= character.name %>" class="character-img">
            <h3><%= character.name %></h3>
            <p><strong>Status:</strong> <%= character.status %></p>
            <p><strong>Species:</strong> <%= character.species %></p>
            <p><strong>Gender:</strong> <%= character.gender %></p>
            <p><strong>Origin:</strong> <%= character.origin.name %></p>
            <p><strong>Location:</strong> <%= character.location.name %></p>
          </div>
        </div>
      <% } %>
    </section>
  </main>

  <%- include('partials/footer') %>
</body>
</html>
