<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Search by Species</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <%- include('partials/nav') %>

  <main class="container">
    <section class="search-section">
      <h1>Search Characters by Species</h1>

      <form method="POST" action="/search-species" class="search-form">
        <div class="form-group">
          <label for="species">Species Name:</label>
          <input 
            type="text" 
            id="species" 
            name="species" 
            placeholder="e.g., Human, Alien, Robot..."
            value="<%= searchSpecies %>"
            required
          >
        </div>
        <button type="submit" class="btn">Search</button>
      </form>

      <% if (error) { %>
        <div class="alert alert-error">
          <%= error %>
        </div>
      <% } %>

      <% if (results && results.length > 0) { %>
        <div class="results">
          <h2>Found <%= results.length %> character(s) of species "<%= searchSpecies %>"</h2>
          <div class="character-grid">
            <% results.forEach(character => { %>
              <div class="character-card">
                <img src="<%= character.image %>" alt="<%= character.name %>" class="character-img">
                <h3><%= character.name %></h3>
                <p><strong>Status:</strong> <%= character.status %></p>
                <p><strong>Species:</strong> <%= character.species %></p>
                <p><strong>Gender:</strong> <%= character.gender %></p>
                <p><strong>Origin:</strong> <%= character.origin.name %></p>
              </div>
            <% }); %>
          </div>
        </div>
      <% } %>
    </section>
  </main>

  <%- include('partials/footer') %>
</body>
</html>
